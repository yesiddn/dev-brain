---
// src/pages/[collection]/[...id].astro
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';

type Collections = 'playbooks' | 'snippets' | 'concepts' | 'lab' | 'stack';

// Type guard: verifica que el data tiene tech (todas menos stack)
function hasTech(data: CollectionEntry<Collections>['data']): data is Extract<CollectionEntry<Collections>['data'], { tech: string[] }> {
  return 'tech' in data;
}

export async function getStaticPaths() {
  const collectionNames: Collections[] = ['playbooks', 'snippets', 'concepts', 'lab', 'stack'];

  const paths = await Promise.all(
    collectionNames.map(async (col) => {
      const entries = await getCollection(col);
      return entries.map(entry => ({
        params: { collection: col, id: entry.id },
        props: { entry, collection: col },
      }));
    })
  );

  return paths.flat();
}

interface Props {
  entry: CollectionEntry<Collections>;
  collection: Collections;
}

const { entry, collection } = Astro.props;
const { Content } = await render(entry);
---

<NoteLayout title={entry.data.title} collection={collection}>
  <div class="mb-6">
    <div class="flex gap-2 flex-wrap mb-2">
      {hasTech(entry.data) && entry.data.tech.map(t => (
        <span class="text-xs bg-teal-900 text-teal-300 rounded px-2 py-0.5">{t}</span>
      ))}
      {entry.data.tags?.map(tag => (
        <span class="text-xs bg-zinc-800 text-zinc-400 rounded px-2 py-0.5">#{tag}</span>
      ))}
    </div>
    <h1 class="text-3xl font-bold text-zinc-100">{entry.data.title}</h1>
    <p class="text-zinc-400 mt-1">{entry.data.description}</p>
    <p class="text-xs text-zinc-600 mt-2">
      Actualizado: {entry.data.updatedAt?.toLocaleDateString('es-CO')}
    </p>
  </div>

  <article class="prose prose-invert prose-zinc max-w-none">
    <Content />
  </article>
</NoteLayout>